# API key del proveedor LLM (requerido)
# Groq: https://console.groq.com/keys
# OpenAI: https://platform.openai.com/api-keys
# LLMs locales (Ollama, LM Studio): usa cualquier valor, e.g. "ollama"
LLM_API_KEY=your_api_key_here

# URL base para APIs compatibles con OpenAI (opcional)
# Groq:      https://api.groq.com/openai/v1
# OpenAI:    https://api.openai.com/v1  (por defecto si se omite)
# Ollama:    http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Modelo a usar (opcional, usa el default del Generator si se omite)
# Groq:   llama-3.3-70b-versatile
# OpenAI: gpt-4o
# Ollama: llama3.2
# LLM_MODEL=llama-3.3-70b-versatile

# Google AI Studio (Gemini)
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.0-flash

# Compatibilidad con versiones anteriores (deprecated, usa LLM_API_KEY)
# GROQ_API_KEY=your_api_key_here
